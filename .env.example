# =============================================================================
# SpecForge — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# PostgreSQL connection string (Neon, Supabase, Railway, or self-hosted)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-1.aws.neon.tech/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth
# Generate a secret with: openssl rand -base64 32
# NEXTAUTH_URL must be the canonical URL of your deployment (no trailing slash)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="your-super-secret-key-change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# App URL (public, used for internal API calls / instrumentation)
# In production set this to your deployed domain, e.g. https://specforge.app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Google Gemini  (primary LLM provider)
# Comma-separated list of API keys — rotated automatically on quota/rate-limit errors
# Used for spec generation, planning, review, tasks, validation, clarification
# Get your keys at https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEYS="your-gemini-api-key-1,your-gemini-api-key-2"

# -----------------------------------------------------------------------------
# OpenRouter  (used for execution-pack generation)
# Comma-separated list of API keys — rotated automatically on quota/rate-limit errors
# Lets you route to any supported model (Gemini, Claude, GPT-4o, etc.)
# Get your keys at https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEYS="your-openrouter-api-key-1,your-openrouter-api-key-2"

# -----------------------------------------------------------------------------
# Cerebras
# Fast inference for AI models
# -----------------------------------------------------------------------------
CEREBRAS_API_KEY="your-cerebras-api-key"
