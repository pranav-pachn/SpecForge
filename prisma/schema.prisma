generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkflowStatus {
  DRAFT
  CLARIFYING
  SPEC_REVIEW
  PLANNING
  TASK_BREAKDOWN
  EXECUTING
  REVIEWING
  VALIDATING
  COMPLETED
  ARCHIVED
}

enum ArtifactType {
  SPEC
  PLAN
  TASK_BREAKDOWN
  EXECUTION_PACK
}

enum ArtifactVersionStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  STALE
  SUPERSEDED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum ClarificationStatus {
  OPEN
  ANSWERED
  DISMISSED
}

enum ReviewCheckType {
  REQUIREMENT_COVERAGE
  TEST_COVERAGE
  ASSUMPTION_RISK
  CONSISTENCY
}

enum CheckStatus {
  PENDING
  PASSED
  FAILED
  SKIPPED
}

enum DriftEntityType {
  TASK
  PACK
  REVIEW
  VALIDATION
}

enum ToolName {
  CURSOR
  CLAUDE_CODE
  WINDSURF
  CUSTOM
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspaces WorkspaceMember[]
  workflows  Workflow[]
}

// Keeping Workspace and WorkspaceMember per MVP requirements,
// though we will hide them in the UI for now.
model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  WorkspaceMember[]
  projects Project[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String    @default("MEMBER")
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflows Workflow[]
}

model Workflow {
  id        String         @id @default(cuid())
  name      String
  status    WorkflowStatus @default(DRAFT)
  projectId String
  creatorId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator   User       @relation(fields: [creatorId], references: [id])
  artifacts Artifact[]
  tasks     Task[]
}

model Artifact {
  id         String       @id @default(cuid())
  workflowId String
  type       ArtifactType
  title      String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  workflow Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  versions ArtifactVersion[]
}

model ArtifactVersion {
  id         String                @id @default(cuid())
  artifactId String
  version    Int
  content    String                @db.Text
  status     ArtifactVersionStatus @default(DRAFT)
  createdAt  DateTime              @default(now())

  artifact            Artifact                @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  driftEvents         DriftEvent[]
  sourceOfDriftEvents DriftEvent[]            @relation("SourceVersion")
  tasks               Task[]
  clarifications      ClarificationQuestion[]
  executionPacks      ExecutionPack[]
  reviewChecks        ReviewCheck[]
  validationChecks    ValidationCheck[]
}

model ClarificationQuestion {
  id        String              @id @default(cuid())
  versionId String
  question  String
  category  String?
  status    ClarificationStatus @default(OPEN)
  createdAt DateTime            @default(now())

  version ArtifactVersion      @relation(fields: [versionId], references: [id], onDelete: Cascade)
  answer  ClarificationAnswer?
}

model ClarificationAnswer {
  id         String   @id @default(cuid())
  questionId String   @unique
  answer     String
  createdAt  DateTime @default(now())

  question ClarificationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Task {
  id                 String     @id @default(cuid())
  workflowId         String
  versionId          String
  title              String
  description        String?    @db.Text
  acceptanceCriteria String?    @db.Text
  verificationNotes  String?    @db.Text
  status             TaskStatus @default(TODO)
  priority           Int?
  order              Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  workflow Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version  ArtifactVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  dependencies TaskDependency[] @relation("DependentTasks")
  dependsOn    TaskDependency[] @relation("TaskDependencies")
  executionPacks ExecutionPack[]
}

model TaskDependency {
  id          String @id @default(cuid())
  taskId      String
  dependsOnId String

  task      Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("DependentTasks", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
}

model ExecutionPack {
  id        String   @id @default(cuid())
  versionId String
  taskId    String?
  toolName  ToolName
  content   String   @db.Text
  createdAt DateTime @default(now())

  version ArtifactVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  task    Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model ReviewCheck {
  id          String          @id @default(cuid())
  versionId   String
  type        ReviewCheckType
  description String
  status      CheckStatus     @default(PENDING)
  createdAt   DateTime        @default(now())

  version ArtifactVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
}

model ValidationCheck {
  id          String      @id @default(cuid())
  versionId   String
  criteria    String
  category    String?
  status      CheckStatus @default(PENDING)
  resultNotes String?     @db.Text
  createdAt   DateTime    @default(now())

  version ArtifactVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
}

model DriftEvent {
  id              String          @id @default(cuid())
  versionId       String          // Downstream artifact version impacted
  sourceVersionId String?         // Changed source version that caused drift
  entityType      DriftEntityType
  entityId        String
  description     String
  resolved        Boolean         @default(false)
  createdAt       DateTime        @default(now())

  version       ArtifactVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  sourceVersion ArtifactVersion? @relation("SourceVersion", fields: [sourceVersionId], references: [id], onDelete: SetNull)
}

model ToolProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  config    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventType {
  WORKFLOW_CREATED
  SPEC_GENERATED
  SPEC_APPROVED
  PLAN_GENERATED
  TASKS_EXPORTED
  REVIEW_ISSUE_RESOLVED
  STALE_ARTIFACT_TRIGGERED
}

model EventLog {
  id          String    @id @default(cuid())
  eventType   EventType
  workflowId  String?
  userId      String?
  metadata    String?   @db.Text // JSON string
  createdAt   DateTime  @default(now())
}
